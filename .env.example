# .env.example — copie para .env e preencha os valores reais
# Este arquivo É versionado (sem segredos); .env NÃO é versionado.

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token do bot (obter em @BotFather)
TELEGRAM_BOT_TOKEN=

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider: gemini | local
LLM_PROVIDER=gemini

# Chave da API do Gemini (aistudio.google.com/apikey — free tier)
GEMINI_API_KEY=

# ── Banco de dados ─────────────────────────────────────────────────────────────
# Connection string do Neon (Postgres)
DATABASE_URL=

# ── Fila SQLite ────────────────────────────────────────────────────────────────
# Caminho da fila no volume Docker (não mudar sem rebuild)
FILA_DB_PATH=/data/fila.db

# ── LLM local (fallback, via SSH) ─────────────────────────────────────────────
# Host SSH da máquina da faculdade (ex: ssh-188 do ~/.ssh/config)
LOCAL_LLM_SSH_HOST=ssh-188
LOCAL_LLM_OLLAMA_URL=http://localhost:11434

# ── Ingestão HTTP ─────────────────────────────────────────────────────────────
# Porta do FastAPI (deve bater com docker-compose.yml)
PORT=8000
